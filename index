<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>张昊 | 个人学术主页</title>
  <style>
    :root {
      --bg: #f7f7f4;
      --paper: #fffefb;
      --paper-2: #fcfbf8;
      --ink: #1e2f4f;
      --ink-soft: #44536d;
      --muted: #69768c;
      --line: #d9dde4;
      --line-soft: #eaedf1;
      --navy: #223c68;
      --navy-2: #304e82;
      --gold: #b08a4a;
      --shadow: 0 18px 40px rgba(34, 60, 104, 0.08);
      --content: 1240px;
      --radius-lg: 24px;
      --radius-md: 16px;
      --radius-sm: 10px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      color: var(--ink);
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      background:
        linear-gradient(180deg, rgba(34, 60, 104, 0.04) 0, rgba(34, 60, 104, 0.04) 1px, transparent 1px, transparent 160px),
        radial-gradient(circle at top right, rgba(176, 138, 74, 0.08), transparent 18%),
        linear-gradient(180deg, #faf9f5 0%, #f5f5f0 100%);
      line-height: 1.8;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      display: block;
      max-width: 100%;
    }

    .container {
      width: min(var(--content), calc(100% - 40px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(16px);
      background: rgba(250, 249, 245, 0.9);
      border-bottom: 1px solid rgba(34, 60, 104, 0.08);
    }

    .topbar-inner {
      width: min(var(--content), calc(100% - 40px));
      margin: 0 auto;
      padding: 24px 0 18px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 24px;
    }

    .brand strong,
    .hero-name,
    .section-title,
    .card-title,
    .footer-name {
      font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", "STSong", serif;
    }

    .brand strong {
      display: block;
      font-size: 1.55rem;
      letter-spacing: 0.04em;
      margin-bottom: 4px;
    }

    .brand span {
      color: var(--ink-soft);
      font-size: 0.98rem;
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      align-items: center;
    }

    .nav a {
      position: relative;
      padding: 6px 2px;
      color: var(--ink-soft);
      font-size: 0.98rem;
    }

    .nav a:first-child {
      color: var(--navy);
      font-weight: 600;
    }

    .nav a:first-child::after,
    .nav a:hover::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -8px;
      height: 2px;
      background: var(--navy);
    }

    .hero {
      padding: 44px 0 18px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.02fr) minmax(380px, 0.98fr);
      gap: 38px;
      align-items: start;
    }

    .hero-left {
      padding: 28px 8px 0 4px;
    }

    .hero-name {
      margin: 0;
      font-size: clamp(3.8rem, 7vw, 5.5rem);
      line-height: 1;
      letter-spacing: 0.18em;
      color: var(--navy);
      font-weight: 600;
    }

    .hero-english {
      margin-top: 18px;
      font-family: "Cormorant Garamond", "Georgia", serif;
      font-size: clamp(2rem, 4vw, 2.7rem);
      letter-spacing: 0.18em;
      color: var(--navy-2);
      font-weight: 700;
      text-transform: uppercase;
    }

    .hero-intro {
      margin: 26px 0 30px;
      max-width: 40em;
      font-size: 1.08rem;
      color: var(--ink-soft);
    }

    .identity-list {
      width: min(100%, 560px);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .identity-row {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 18px;
      padding: 16px 0;
      border-bottom: 1px solid var(--line-soft);
    }

    .identity-row:last-child {
      border-bottom: 0;
    }

    .identity-row span {
      color: var(--ink-soft);
      font-weight: 600;
    }

    .identity-row strong {
      color: var(--ink);
      font-weight: 600;
    }

    .hero-card {
      overflow: hidden;
      background: var(--paper);
      border: 1px solid rgba(34, 60, 104, 0.1);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
    }

    .hero-visual {
      position: relative;
      height: 260px;
      background:
        radial-gradient(circle at 84% 18%, rgba(255, 255, 255, 0.14), transparent 10%),
        radial-gradient(circle at 18% 80%, rgba(79, 158, 255, 0.14), transparent 18%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 48%),
        linear-gradient(145deg, #0c1930 0%, #17345d 52%, #21467d 100%);
    }

    .hero-visual::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px 10px),
        repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 10px);
      opacity: 0.38;
    }

    .hero-visual::after {
      content: "";
      position: absolute;
      inset: 18px 20px auto auto;
      width: 104px;
      height: 104px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background:
        radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.14) 0 1px, transparent 2px),
        radial-gradient(circle at 50% 50%, transparent 0 32%, rgba(255, 255, 255, 0.12) 33%, transparent 34%),
        radial-gradient(circle at 50% 50%, transparent 0 49%, rgba(255, 255, 255, 0.1) 50%, transparent 51%);
      opacity: 0.65;
    }

    .optics-chip,
    .optics-path,
    .optics-label,
    .optics-node,
    .optics-pulse {
      position: absolute;
      z-index: 1;
    }

    .optics-chip {
      border: 1px solid rgba(255, 255, 255, 0.34);
      background: rgba(247, 249, 255, 0.08);
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    }

    .chip-source {
      left: 26px;
      top: 112px;
      width: 56px;
      height: 26px;
      border-radius: 8px;
    }

    .chip-splitter {
      left: 132px;
      top: 102px;
      width: 18px;
      height: 18px;
      transform: rotate(45deg);
      border-radius: 3px;
    }

    .chip-delay {
      left: 164px;
      top: 34px;
      width: 82px;
      height: 18px;
      border-radius: 999px;
    }

    .chip-lens {
      left: 248px;
      top: 78px;
      width: 16px;
      height: 56px;
      border-radius: 999px;
    }

    .chip-sample {
      right: 72px;
      top: 110px;
      width: 20px;
      height: 60px;
      border-radius: 8px;
    }

    .chip-detector {
      right: 22px;
      top: 104px;
      width: 34px;
      height: 72px;
      border-radius: 10px;
    }

    .optics-path {
      height: 4px;
      border-radius: 999px;
      transform-origin: left center;
      box-shadow: 0 0 12px currentColor;
    }

    .path-seed {
      left: 82px;
      top: 122px;
      width: 56px;
      color: rgba(255, 219, 120, 0.95);
      background: currentColor;
    }

    .path-pump-a {
      left: 142px;
      top: 110px;
      width: 70px;
      color: rgba(255, 166, 97, 0.92);
      background: currentColor;
      transform: rotate(-46deg);
    }

    .path-pump-b {
      left: 212px;
      top: 62px;
      width: 132px;
      color: rgba(255, 166, 97, 0.92);
      background: currentColor;
    }

    .path-probe-a {
      left: 144px;
      top: 122px;
      width: 108px;
      color: rgba(107, 202, 255, 0.96);
      background: currentColor;
    }

    .path-probe-b {
      left: 262px;
      top: 122px;
      width: 106px;
      color: rgba(107, 202, 255, 0.96);
      background: currentColor;
    }

    .path-detect {
      left: 368px;
      top: 140px;
      width: 42px;
      color: rgba(255, 255, 255, 0.88);
      background: currentColor;
    }

    .optics-node {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 0 12px rgba(255, 255, 255, 0.6);
    }

    .node-split {
      left: 138px;
      top: 116px;
    }

    .node-sample {
      left: 366px;
      top: 136px;
      background: rgba(255, 243, 184, 0.94);
      box-shadow: 0 0 12px rgba(255, 215, 120, 0.78);
    }

    .optics-label {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(240, 244, 255, 0.86);
      font-weight: 700;
      z-index: 2;
    }

    .label-source {
      left: 22px;
      top: 146px;
    }

    .label-delay {
      left: 170px;
      top: 16px;
    }

    .label-pump {
      left: 254px;
      top: 48px;
      color: rgba(255, 201, 139, 0.96);
    }

    .label-probe {
      left: 218px;
      top: 132px;
      color: rgba(164, 226, 255, 0.98);
    }

    .label-sample {
      right: 62px;
      top: 176px;
    }

    .label-detector {
      right: 18px;
      top: 84px;
    }

    .optics-pulse {
      left: 324px;
      top: 134px;
      width: 26px;
      height: 12px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(255, 189, 99, 0.2), rgba(255, 255, 255, 0.98), rgba(111, 204, 255, 0.2));
      filter: blur(0.2px);
      box-shadow: 0 0 12px rgba(255, 255, 255, 0.5);
    }

    .hero-card-body {
      padding: 26px 28px 30px;
    }

    .eyebrow,
    .section-subtitle,
    .small-label {
      font-family: "Georgia", serif;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--navy-2);
    }

    .eyebrow {
      font-size: 0.9rem;
      margin-bottom: 10px;
      font-weight: 700;
    }

    .hero-card h2 {
      margin: 0 0 10px;
      font-family: "Cormorant Garamond", "Georgia", serif;
      font-size: 2rem;
      line-height: 1.25;
      color: var(--ink);
    }

    .hero-card p {
      margin: 0 0 18px;
      color: var(--ink-soft);
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .tag {
      padding: 8px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--ink-soft);
      background: var(--paper-2);
      font-size: 0.92rem;
    }

    .divider {
      height: 1px;
      background: linear-gradient(90deg, rgba(34, 60, 104, 0.12), rgba(34, 60, 104, 0.02));
      margin: 20px 0 28px;
    }

    .research-grid {
      display: grid;
      grid-template-columns: 220px repeat(4, minmax(0, 1fr));
      gap: 0;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.38);
    }

    .research-header,
    .research-item {
      padding: 30px 22px;
    }

    .research-header {
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 1px solid var(--line-soft);
    }

    .section-title {
      margin: 0 0 6px;
      font-size: clamp(2rem, 3vw, 2.6rem);
      line-height: 1.12;
      color: var(--navy);
    }

    .section-subtitle {
      margin: 0;
      font-size: 0.98rem;
      font-weight: 700;
    }

    .title-mark {
      width: 56px;
      height: 2px;
      background: var(--navy-2);
      margin-top: 18px;
    }

    .research-item {
      border-right: 1px solid var(--line-soft);
    }

    .research-item:last-child {
      border-right: 0;
    }

    .research-icon {
      width: 50px;
      height: 50px;
      margin-bottom: 16px;
      position: relative;
      color: var(--navy);
    }

    .icon-wave::before,
    .icon-wave::after,
    .icon-hex::before,
    .icon-node::before,
    .icon-stack::before {
      content: "";
      position: absolute;
      inset: 0;
    }

    .icon-wave::before {
      border: 2px solid currentColor;
      border-radius: 50%;
      transform: scale(0.88);
    }

    .icon-wave::after {
      border-top: 2px solid currentColor;
      border-bottom: 2px solid currentColor;
      border-radius: 50%;
      inset: 12px 4px;
    }

    .icon-hex::before {
      clip-path: polygon(25% 7%, 75% 7%, 100% 50%, 75% 93%, 25% 93%, 0 50%);
      border: 2px solid currentColor;
      background: linear-gradient(currentColor, currentColor) center/2px 70% no-repeat;
    }

    .icon-node::before {
      background:
        radial-gradient(circle, currentColor 0 2px, transparent 3px) 10% 30%/100% 100% no-repeat,
        radial-gradient(circle, currentColor 0 2px, transparent 3px) 50% 10%/100% 100% no-repeat,
        radial-gradient(circle, currentColor 0 2px, transparent 3px) 84% 34%/100% 100% no-repeat,
        radial-gradient(circle, currentColor 0 2px, transparent 3px) 20% 78%/100% 100% no-repeat,
        radial-gradient(circle, currentColor 0 2px, transparent 3px) 60% 84%/100% 100% no-repeat,
        linear-gradient(currentColor, currentColor) 28% 38%/46% 1px no-repeat,
        linear-gradient(currentColor, currentColor) 20% 64%/42% 1px no-repeat,
        linear-gradient(currentColor, currentColor) 52% 58%/30% 1px no-repeat,
        linear-gradient(currentColor, currentColor) 36% 24%/1px 50% no-repeat;
      opacity: 0.9;
    }

    .icon-stack::before {
      background:
        linear-gradient(currentColor, currentColor) center 20%/80% 2px no-repeat,
        linear-gradient(currentColor, currentColor) center 50%/80% 2px no-repeat,
        linear-gradient(currentColor, currentColor) center 80%/80% 2px no-repeat;
      box-shadow:
        inset 0 0 0 2px transparent,
        0 0 0 0 transparent;
      transform: perspective(100px) rotateX(60deg);
    }

    .research-item h3,
    .panel h3 {
      margin: 0 0 10px;
      font-size: 1.35rem;
      color: var(--navy);
    }

    .research-item p,
    .intro-text,
    .panel p {
      margin: 0;
      color: var(--ink-soft);
      font-size: 0.98rem;
    }

    main section {
      padding: 30px 0;
    }

    .two-column {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 36px;
      align-items: start;
    }

    .section-block {
      min-width: 0;
    }

    .left-column {
      display: grid;
      gap: 28px;
      min-width: 0;
    }

    .timeline {
      position: relative;
      padding-left: 26px;
      margin-top: 26px;
      border-left: 1px solid var(--line);
    }

    .timeline-item {
      position: relative;
      padding: 0 0 28px 18px;
    }

    .timeline-item:last-child {
      padding-bottom: 0;
    }

    .timeline-item::before {
      content: "";
      position: absolute;
      left: -32px;
      top: 6px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--navy);
      box-shadow: 0 0 0 4px rgba(34, 60, 104, 0.08);
    }

    .timeline-date {
      display: block;
      color: var(--ink-soft);
      font-weight: 700;
      margin-bottom: 6px;
    }

    .timeline-item h4 {
      margin: 0 0 4px;
      font-size: 1.08rem;
      color: var(--ink);
    }

    .timeline-item p {
      margin: 0;
      color: var(--muted);
      font-size: 0.96rem;
    }

    .timeline-note {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .pub-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 16px;
      margin-bottom: 22px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line);
    }

    .more-link {
      color: var(--navy-2);
      font-weight: 600;
      white-space: nowrap;
    }

    .pub-list {
      display: grid;
      gap: 22px;
    }

    .pub-item {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 16px;
      align-items: start;
      padding-bottom: 18px;
      border-bottom: 1px dashed var(--line);
    }

    .pub-item:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .pub-index {
      color: var(--navy);
      font-family: "Georgia", serif;
      font-weight: 700;
    }

    .pub-item h4 {
      margin: 0 0 8px;
      font-size: 1.18rem;
      line-height: 1.55;
      color: var(--ink);
    }

    .pub-item h4 a:hover {
      color: var(--navy-2);
    }

    .pub-meta {
      color: var(--ink-soft);
      font-size: 0.97rem;
    }

    .pub-note {
      display: block;
      margin-top: 6px;
      color: var(--navy);
      font-weight: 600;
    }

    .grid-two {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .panel {
      background: rgba(255, 255, 255, 0.68);
      border: 1px solid rgba(34, 60, 104, 0.09);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-body {
      padding: 28px;
    }

    .plain-panel {
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      overflow: visible;
    }

    .plain-panel .panel-body {
      padding: 0;
    }

    .plain-panel .list-card {
      padding: 0;
      margin-bottom: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
    }

    .card-title {
      margin: 0 0 8px;
      font-size: 2rem;
      line-height: 1.15;
      color: var(--navy);
    }

    .list-card {
      padding: 18px 18px 16px;
      border: 1px solid var(--line-soft);
      border-radius: var(--radius-sm);
      background: rgba(255, 255, 255, 0.66);
      margin-bottom: 14px;
    }

    .list-card:last-child {
      margin-bottom: 0;
    }

    .list-card strong {
      display: block;
      margin-bottom: 6px;
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--ink);
    }

    .list-card span {
      color: var(--muted);
      font-size: 0.95rem;
    }

    .contact {
      display: grid;
      grid-template-columns: 0.8fr 1.2fr;
      gap: 26px;
      align-items: end;
      padding: 10px 0 0;
    }

    .contact-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .contact-card {
      padding: 20px 18px;
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid rgba(34, 60, 104, 0.08);
      border-radius: var(--radius-sm);
    }

    .small-label {
      display: block;
      margin-bottom: 8px;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .contact-card strong {
      color: var(--ink);
      word-break: break-all;
    }

    footer {
      margin-top: 28px;
      background: #203861;
      color: rgba(255, 255, 255, 0.88);
    }

    .footer-inner {
      width: min(var(--content), calc(100% - 40px));
      margin: 0 auto;
      padding: 24px 0;
      text-align: center;
      font-size: 0.95rem;
    }

    @media (max-width: 1100px) {
      .hero-grid,
      .two-column,
      .contact,
      .grid-two {
        grid-template-columns: 1fr;
      }

      .research-grid {
        grid-template-columns: 1fr 1fr;
      }

      .research-header {
        grid-column: 1 / -1;
        border-right: 0;
        border-bottom: 1px solid var(--line-soft);
      }

      .research-item:nth-child(3) {
        border-right: 0;
      }
    }

    @media (max-width: 760px) {
      .container,
      .topbar-inner,
      .footer-inner {
        width: min(var(--content), calc(100% - 24px));
      }

      .topbar-inner {
        align-items: flex-start;
        flex-direction: column;
      }

      .nav {
        gap: 14px 18px;
      }

      .hero {
        padding-top: 26px;
      }

      .hero-left {
        padding-top: 0;
      }

      .hero-name {
        font-size: 3.4rem;
        letter-spacing: 0.12em;
      }

      .hero-english {
        font-size: 1.9rem;
      }

      .identity-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .research-grid,
      .contact-meta {
        grid-template-columns: 1fr;
      }

      .research-item {
        border-right: 0;
        border-top: 1px solid var(--line-soft);
      }

      .panel-body,
      .hero-card-body {
        padding: 22px 20px;
      }

      .hero-visual {
        height: 210px;
      }

      .pub-item {
        grid-template-columns: 1fr;
        gap: 8px;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>张昊学术主页</strong>
        <span>Nanjing University of Posts and Telecommunications · Electronic and Optical Engineering</span>
      </div>
      <nav class="nav">
        <a href="#top">首页</a>
        <a href="#about">简介</a>
        <a href="#research">研究</a>
